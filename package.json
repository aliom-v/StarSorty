{
  "name": "starsorty",
  "private": true,
  "scripts": {
    "dev": "node scripts/run-platform.js dev",
    "start": "node scripts/run-platform.js start",
    "stop": "node scripts/run-platform.js stop",
    "status": "node scripts/run-platform.js status",
    "dev:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows/dev.ps1",
    "start:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows/start.ps1",
    "stop:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows/stop.ps1",
    "status:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows/status.ps1",
    "dev:unix": "bash scripts/unix/dev.sh",
    "start:unix": "bash scripts/unix/start.sh",
    "stop:unix": "bash scripts/unix/stop.sh",
    "status:unix": "bash scripts/unix/status.sh",
    "api:test": "node scripts/run-api-tests.js",
    "api:bench": "python evaluation/benchmark_api_perf.py",
    "web:dev": "npm --prefix web run dev",
    "web:build": "npm --prefix web run build",
    "web:lint": "npm --prefix web run lint",
    "web:smoke": "npm --prefix web run smoke"
  }
}
