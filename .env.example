# --- GitHub targets ---
# Primary username to sync (optional if using GITHUB_USERNAMES or token-based sync)
GITHUB_USERNAME=
# Optional extra target username
GITHUB_TARGET_USERNAME=
# Comma- or newline-separated list of usernames
GITHUB_USERNAMES=
# Include the authenticated user when a token is provided
GITHUB_INCLUDE_SELF=false
# merge | group
GITHUB_MODE=merge
# GitHub token (recommended to avoid rate limits)
GITHUB_TOKEN=
# Admin token required for write operations (sync/classify/settings)
ADMIN_TOKEN=
# Runtime env: set to production in deployment to enable strict security checks
# development | production
APP_ENV=development
# GitHub Enterprise API base URL (optional)
GITHUB_API_BASE_URL=https://api.github.com

# --- Classification mode ---
# rules_then_ai | ai_only | rules_only
CLASSIFY_MODE=ai_only
AUTO_CLASSIFY_AFTER_SYNC=true

# --- AI provider ---
# openai | anthropic | custom | none
AI_PROVIDER=none
AI_API_KEY=
AI_MODEL=
# For custom provider, include /v1 if required
AI_BASE_URL=
# Optional JSON string for extra headers
AI_HEADERS_JSON=
AI_TEMPERATURE=0.2
AI_MAX_TOKENS=500
AI_TIMEOUT=30
# Optional custom taxonomy file path
AI_TAXONOMY_PATH=
# Optional JSON string for rules (overrides api/config/rules.json)
RULES_JSON=
# --- Refactor feature flags ---
CLASSIFY_ENGINE_V2_ENABLED=1
SEARCH_RANKER_V2_ENABLED=1
# Relevance 排序候选集上限，避免全量拉取后内存重排
RELEVANCE_CANDIDATE_LIMIT=2000
# 同步阶段 star_users 预加载分批查询大小（避免 SQLite 参数上限）
STAR_USER_LOOKUP_CHUNK_SIZE=400
# taxonomy/rules 进程内缓存 TTL（秒，0 表示禁用缓存）
TAXONOMY_CACHE_TTL_SECONDS=300
RULES_CACHE_TTL_SECONDS=300
# Rule decision thresholds for classify_mode=rules_then_ai
RULE_DIRECT_THRESHOLD=0.88
RULE_AI_THRESHOLD=0.45

# --- Scheduler / sync ---
SYNC_CRON=0 */6 * * *
SYNC_TIMEOUT=30

# --- Storage / network ---
DATABASE_URL=sqlite:////data/app.db
# Comma-separated explicit origins (do not use * in production)
CORS_ORIGINS=http://localhost:1234
# Internal API base for scheduler container
API_BASE_URL=http://api:4321
# Public API base for web build
NEXT_PUBLIC_API_BASE_URL=http://localhost:4321
LOG_LEVEL=INFO

# --- Classification batching ---
CLASSIFY_BATCH_SIZE=50
CLASSIFY_CONCURRENCY=3
CLASSIFY_CONCURRENCY_MAX=10
CLASSIFY_BATCH_DELAY_MS=0

# --- Rate limiting ---
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_ADMIN=30/minute
RATE_LIMIT_HEAVY=10/minute
